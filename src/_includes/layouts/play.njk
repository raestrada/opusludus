---
layout: layouts/base.njk
title: Opus Ludus
---

<script>
  document.documentElement.classList.add('play-page-active');
  document.body.classList.add('play-page-active');
</script>

<div class="play-page">
  <div class="game-container" id="game-container">
    
    <!-- 1. LESSON VIEW (VISIBLE BY DEFAULT) -->
    <div class="lesson-view" id="lesson-view">
      <div class="lesson-header">
        <span class="lesson-badge">Lección Teórica</span>
        <h1 id="lesson-title" class="lesson-main-title">Cargando Lección...</h1>
      </div>
      
      <div class="lesson-body">
        <!-- Left: Explanations -->
        <div class="lesson-text-panel">
          <p id="lesson-intro" class="lesson-intro-text">Cargando teoría del conservatorio...</p>
          <ul id="lesson-details-list" class="lesson-details-list">
            <!-- Bullet points -->
          </ul>
          <button class="btn btn-success btn-large" id="lesson-btn-start">
            {% if locale == 'es' %}Siguiente{% else %}Next{% endif %} <span class="icon">➔</span>
          </button>
        </div>
        
        <!-- Right: Interactive Notation Example -->
        <div class="lesson-example-panel">
          <h3 id="lesson-example-title">Ejemplo Musical</h3>
          <div class="lesson-staff-wrapper">
            <div id="lesson-staff-area"></div>
          </div>
          <p id="lesson-example-desc" class="lesson-example-desc">...</p>
          <div class="lesson-example-controls">
            <button class="btn btn-secondary" id="lesson-btn-play-example">
              <span class="icon">▶</span> {% if locale == 'es' %}Escuchar Ejemplo{% else %}Play Example{% endif %}
            </button>
            <button class="btn btn-stop" id="lesson-btn-stop-example" style="display:none;">
              <span class="icon">■</span> {% if locale == 'es' %}Detener{% else %}Stop{% endif %}
            </button>
            <button class="btn btn-secondary" id="lesson-btn-zoom-example">
              <span class="icon">🔍</span> {% if locale == 'es' %}Ver Completo{% else %}View Full{% endif %}
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- 2. CHALLENGE OVERVIEW VIEW (HIDDEN BY DEFAULT) -->
    <div class="challenge-view hidden" id="challenge-view">
      <div class="challenge-view-header">
        <span class="challenge-badge">{% if locale == 'es' %}Desafío de Composición{% else %}Composition Challenge{% endif %}</span>
        <h1 id="challenge-title-text" class="challenge-main-title">Cargando Objetivo...</h1>
      </div>
      
      <div class="challenge-view-body">
        <div class="challenge-info-card">
          <div class="challenge-icon-large">🎯</div>
          <div class="challenge-text-content">
            <h3>{% if locale == 'es' %}Objetivo Principal{% else %}Main Goal{% endif %}</h3>
            <p>{% if locale == 'es' %}Escribe tu composición en el pentagrama interactivo cumpliendo los siguientes requisitos pedagógicos:{% else %}Compose your piece on the interactive staff satisfying the following pedagogical requirements:{% endif %}</p>
          </div>
        </div>

        <div class="challenge-rules-container">
          <h3>{% if locale == 'es' %}Requisitos de Evaluación{% else %}Evaluation Requirements{% endif %}</h3>
          <ul id="play-challenge-rules" class="challenge-rules-list-large">
            <!-- Populated dynamically -->
          </ul>
        </div>

        <div class="challenge-actions">
          <button class="btn btn-secondary" id="challenge-btn-back">
            {% if locale == 'es' %}← Volver a la Teoría{% else %}← Back to Theory{% endif %}
          </button>
          <button class="btn btn-success btn-large" id="challenge-btn-start">
            {% if locale == 'es' %}¡A Jugar!{% else %}Play!{% endif %} <span class="icon">➔</span>
          </button>
        </div>
      </div>
    </div>

    <!-- 2. GAME PLAY VIEW (HIDDEN BY DEFAULT) -->
    <div class="game-workspace hidden" id="game-workspace">
      <!-- Game HUD -->
      <div class="game-hud">
        <div class="hud-left">
          <a href="{{ pathPrefix }}/{{ locale }}/modules/" class="hud-back-btn">← {{ play.back | default("Volver a Módulos") }}</a>
          <h2 id="hud-module-title" class="hud-title">Cargando módulo...</h2>
        </div>
        <div class="hud-right">
          <div class="hud-actions-group">
            <button class="btn btn-secondary btn-sm" id="hud-btn-objectives" title="{% if locale == 'es' %}Ver Requisitos{% else %}View Requirements{% endif %}">
              <span class="icon">🎯</span> {% if locale == 'es' %}Requisitos{% else %}Requirements{% endif %}
            </button>
            <button class="btn btn-secondary btn-sm" id="hud-btn-tips" title="{% if locale == 'es' %}Ver Teoría{% else %}View Theory{% endif %}">
              <span class="icon">💡</span> {% if locale == 'es' %}Teoría{% else %}Theory{% endif %}
            </button>
            <button class="btn btn-secondary btn-sm" id="hud-btn-aids" title="{% if locale == 'es' %}Ayudas Visuales{% else %}Visual Aids{% endif %}">
              <span class="icon">🔍</span> {% if locale == 'es' %}Ayudas{% else %}Aids{% endif %}
            </button>
          </div>
          <span class="hud-stat xp"><span class="icon">🎵</span> <span id="hud-xp-value">0</span> XP</span>
          <span class="hud-stat streak" id="hud-streak-container" style="display:none;"><span class="icon">🔥</span> <span id="hud-streak-value">0</span></span>
        </div>
      </div>
      
      <!-- Tips / Module Instruction -->
      <div class="hud-tips-bar">
        <p id="hud-tip-text" class="tip-text">Cargando...</p>
      </div>

      <!-- Game Board -->
      <div class="game-board">
        
        <!-- Staff Score Section -->
        <div class="staff-section">
          <div id="opus-staff-area"></div>
          
          <!-- Measure Navigation -->
          <div class="measure-nav" id="measure-nav-container">
            <!-- Populated by JS -->
          </div>
        </div>

        <!-- Controls Panel -->
        <div class="controls-panel">
          
          <div class="palettes-row">
            <!-- Durations -->
            <div class="palette-group flex-1">
              <span class="group-label">Duración</span>
              <div class="duration-palette" id="duration-palette-container">
                <!-- Populated by JS -->
              </div>
            </div>
            
            <!-- Notes -->
            <div class="palette-group flex-2">
              <span class="group-label">Notas permitidas</span>
              <div class="note-palette" id="note-palette-container">
                <!-- Populated by JS -->
              </div>
            </div>
          </div>

          <!-- Keyboard -->
          <div class="palette-group">
            <span class="group-label">Teclado de Piano</span>
            <div class="piano-keyboard-wrapper">
              <div class="piano-keyboard" id="piano-keyboard-container">
                <!-- Populated by JS -->
              </div>
            </div>
          </div>

          <!-- Transport Buttons -->
          <div class="transport-controls">
            <button class="btn btn-secondary" id="btn-reset" title="Reiniciar">
              <span class="icon">↺</span> Reiniciar
            </button>
            <button class="btn btn-secondary" id="btn-undo" title="Deshacer">
              <span class="icon">↩</span> Deshacer
            </button>
            <button class="btn btn-play" id="btn-play" title="Reproducir">
              <span class="icon">▶</span> Reproducir
            </button>
            <button class="btn btn-stop" id="btn-stop" title="Detener" style="display: none;">
              <span class="icon">■</span> Detener
            </button>
            <button class="btn btn-warn" id="btn-evaluate">
              Evaluar desafío
            </button>
            <button class="btn btn-success" id="btn-submit">
              ✓ Guardar y Terminar
            </button>
          </div>

          <!-- Feedback Messages -->
          <div class="feedback-area" id="feedback-message-container"></div>

        </div>
      </div>
    </div>

    <!-- Result Modal (Hidden by default) -->
    <div class="result-overlay hidden" id="result-modal">
      <div class="result-content">
        <h1 id="result-title">¡Buen trabajo!</h1>
        <p id="result-subtitle">El pentagrama, claves y notas</p>
        
        <!-- Stars Container -->
        <div class="result-stars" id="result-stars-container">
          <!-- ⭐⭐⭐ -->
        </div>

        <div class="result-score" id="result-score-value">95%</div>
        
        <!-- Score Penalty Breakdown -->
        <div class="score-breakdown-container" id="score-breakdown-area" style="display:none; margin: 0.5rem 0 1rem; font-size: 0.95rem; color: #a0a0b8;">
          <span id="breakdown-base-score">Base: 100%</span> | 
          <span id="breakdown-penalty" style="color: #ff5252;">{% if locale == 'es' %}Ayudas: -20%{% else %}Aids: -20%{% endif %}</span>
        </div>

        <div class="result-xp-earned" id="result-xp-value">+50 XP</div>
        
        <div class="result-streak" id="result-streak-container" style="display:none;">
          🔥 <span id="result-streak-value">0</span> días seguidos!
        </div>

        <div class="result-actions">
          <button class="btn btn-secondary" id="result-btn-retry">Reintentar</button>
          <button class="btn btn-success" id="result-btn-next" style="display:none;">Siguiente</button>
        </div>

        <button class="btn-link" id="result-btn-menu">← Volver al menú</button>
      </div>
    </div>

    <!-- Objectives Modal (In-game lookup) -->
    <div class="result-overlay hidden" id="objectives-modal">
      <div class="result-content modal-content-custom">
        <h2>🎯 {% if locale == 'es' %}Requisitos de Evaluación{% else %}Evaluation Requirements{% endif %}</h2>
        <ul id="objectives-modal-list" class="challenge-rules-list-large">
          <!-- Populated by JS -->
        </ul>
        <div class="result-actions">
          <button class="btn btn-success" id="objectives-modal-close">{% if locale == 'es' %}Entendido{% else %}Got it{% endif %}</button>
        </div>
      </div>
    </div>

    <!-- Theory & Tips Modal (In-game lookup) -->
    <div class="result-overlay hidden" id="theory-tips-modal">
      <div class="result-content modal-content-custom">
        <h2>💡 {% if locale == 'es' %}Tips Teóricos y Visuales{% else %}Theory & Visual Tips{% endif %}</h2>
        <div id="theory-tips-modal-content" class="theory-tips-body">
          <!-- Populated by JS -->
        </div>
        <div class="result-actions">
          <button class="btn btn-success" id="theory-tips-modal-close">{% if locale == 'es' %}Entendido{% else %}Got it{% endif %}</button>
        </div>
      </div>
    </div>

    <!-- Visual Aids Modal (In-game lookup) -->
    <div class="result-overlay hidden" id="visual-aids-modal">
      <div class="result-content modal-content-custom">
        <h2>🔍 {% if locale == 'es' %}Panel de Ayudas Visuales{% else %}Visual Aids Panel{% endif %}</h2>
        <p class="modal-intro-text" style="color: #a0a0b8; font-size: 0.95rem; margin-bottom: 1.5rem;">
          {% if locale == 'es' %}
            Si te trabas, puedes activar estas ayudas visuales. **Atención**: cada ayuda activada te restará puntos de tu calificación final en este módulo.
          {% else %}
            If you get stuck, you can activate these visual aids. **Note**: each activated aid will deduct points from your final score in this module.
          {% endif %}
        </p>
        
        <div class="visual-aids-list" style="display: flex; flex-direction: column; gap: 1rem; text-align: left; margin-bottom: 1.5rem;">
          <!-- Piano Aid -->
          <div class="aid-item" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); padding: 1rem; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; gap: 1rem;">
            <div class="aid-info" style="flex: 1;">
              <h4 style="margin: 0 0 0.25rem 0; color: #e8e8f0; font-size: 1.05rem;">🎹 {% if locale == 'es' %}Pista 1: Iluminar Piano de Ayuda{% else %}Aid 1: Highlight Helper Piano{% endif %}</h4>
              <p style="margin: 0; color: #a0a0b8; font-size: 0.85rem;">{% if locale == 'es' %}Resalta las teclas permitidas del piano con un color verde brillante para encontrarlas fácilmente.{% else %}Highlight allowed piano keys with a bright green color to find them easily.{% endif %}</p>
            </div>
            <div class="aid-action" style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; min-width: 90px;">
              <span class="aid-penalty" style="color: #f0c040; font-weight: bold; font-size: 0.9rem;">-10%</span>
              <button class="btn btn-warn btn-sm" id="btn-toggle-aid-piano" style="width: 100%; justify-content: center; padding: 4px 8px; font-size: 0.8rem;">{% if locale == 'es' %}Activar{% else %}Activate{% endif %}</button>
            </div>
          </div>

          <!-- Highlight Errors Aid -->
          <div class="aid-item" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); padding: 1rem; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; gap: 1rem;">
            <div class="aid-info" style="flex: 1;">
              <h4 style="margin: 0 0 0.25rem 0; color: #e8e8f0; font-size: 1.05rem;">❌ {% if locale == 'es' %}Pista 2: Resaltar Errores en Rojo{% else %}Aid 2: Highlight Errors in Red{% endif %}</h4>
              <p style="margin: 0; color: #a0a0b8; font-size: 0.85rem;">{% if locale == 'es' %}Dibuja de color rojo brillante directamente en la partitura cualquier nota que no cumpla con los requisitos del desafío.{% else %}Color in bright red directly on the staff any notes that violate the challenge requirements.{% endif %}</p>
            </div>
            <div class="aid-action" style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; min-width: 90px;">
              <span class="aid-penalty" style="color: #f0c040; font-weight: bold; font-size: 0.9rem;">-20%</span>
              <button class="btn btn-warn btn-sm" id="btn-toggle-aid-errors" style="width: 100%; justify-content: center; padding: 4px 8px; font-size: 0.8rem;">{% if locale == 'es' %}Activar{% else %}Activate{% endif %}</button>
            </div>
          </div>

          <!-- Note Suggestion Aid -->
          <div class="aid-item" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); padding: 1rem; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; gap: 1rem;">
            <div class="aid-info" style="flex: 1;">
              <h4 style="margin: 0 0 0.25rem 0; color: #e8e8f0; font-size: 1.05rem;">💡 {% if locale == 'es' %}Pista 3: Sugerir Siguiente Nota{% else %}Aid 3: Suggest Next Note{% endif %}</h4>
              <p style="margin: 0; color: #a0a0b8; font-size: 0.85rem;">{% if locale == 'es' %}Genera y muestra una sugerencia melódica consonante basada en la última nota escrita.{% else %}Generate and show a consonant melodic recommendation based on the last written note.{% endif %}</p>
            </div>
            <div class="aid-action" style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; min-width: 90px;">
              <span class="aid-penalty" style="color: #f0c040; font-weight: bold; font-size: 0.9rem;">-15%</span>
              <button class="btn btn-warn btn-sm" id="btn-toggle-aid-suggest" style="width: 100%; justify-content: center; padding: 4px 8px; font-size: 0.8rem;">{% if locale == 'es' %}Activar{% else %}Activate{% endif %}</button>
            </div>
          </div>
        </div>

        <div class="result-actions">
          <button class="btn btn-success" id="visual-aids-modal-close">{% if locale == 'es' %}Entendido{% else %}Got it{% endif %}</button>
        </div>
      </div>
    </div>

    <!-- Full Score Modal -->
    <div class="result-overlay hidden" id="full-score-modal">
      <div class="result-content modal-content-custom" style="max-width: 900px; width: 95%;">
        <h2>🎼 {% if locale == 'es' %}Partitura Completa{% else %}Full Score{% endif %}</h2>
        <p style="color: #a0a0b8; font-size: 0.9rem; margin-bottom: 1rem;">
          {% if locale == 'es' %}Ejemplo completo del tema musical de la lección.{% else %}Full musical theme example for this lesson.{% endif %}
        </p>
        <div class="full-score-wrapper" style="background: #111128; padding: 1rem; border-radius: 8px; max-height: 60vh; overflow-y: auto; border: 1px solid rgba(255, 255, 255, 0.1); margin-bottom: 1.5rem;">
          <div id="full-score-staff-area" style="width: 100%;"></div>
        </div>
        <div class="result-actions" style="margin-top: 0; justify-content: center;">
          <button class="btn btn-success" id="full-score-modal-close">{% if locale == 'es' %}Cerrar{% else %}Close{% endif %}</button>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  window.__OPUS_LUDUS__ = {
    locale: "{{ locale }}",
    baseUrl: "{{ pathPrefix }}/{{ locale }}/",
    pathPrefix: "{{ pathPrefix }}",
    curriculum: {{ curriculum.modules | dump | safe }}
  };
</script>
{% gameBundle %}
