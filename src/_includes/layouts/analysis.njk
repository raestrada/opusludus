---
layout: layouts/base.njk
title: Opus Ludus — Masterpiece Analysis
---

<div class="analysis-page" style="--analysis-bg-url: url('{{ pathPrefix }}/assets/images/analysis_bg.png');">
  <div class="analysis-container">
    
    <!-- Left Sidebar: Masterpieces Catalog -->
    <aside class="analysis-sidebar">
      <div class="sidebar-header">
        <h2>{% if locale == 'es' %}Obras Maestras{% else %}Masterpieces{% endif %}</h2>
        <p>{% if locale == 'es' %}Selecciona una obra para analizar y reconstruir{% else %}Select a piece to analyze & reconstruct{% endif %}</p>
      </div>
      
      <div class="masterpiece-list" id="masterpiece-list">
        <!-- Populated dynamically via JS -->
      </div>
    </aside>
    
    <!-- Right Panel: Workstation -->
    <main class="analysis-workstation">
      <div class="workstation-card glass-panel" id="analysis-empty-state">
        <div class="empty-content">
          <span class="empty-icon">🎼</span>
          <h3>{% if locale == 'es' %}Comienza el Análisis{% else %}Start the Analysis{% endif %}</h3>
          <p>{% if locale == 'es' %}Selecciona una obra maestra del catálogo izquierdo para cargar la partitura y comenzar el desafío.{% else %}Select a masterpiece from the left catalog to load the stave and begin the challenge.{% endif %}</p>
        </div>
      </div>
      
      <div class="workstation-card glass-panel hidden" id="analysis-content">
        <!-- Workstation Header -->
        <div class="workstation-header">
          <div class="header-left">
            <span class="badge" id="challenge-concept">Concept</span>
            <h1 id="challenge-title">Mozart — Symphony No. 40</h1>
          </div>
          <div class="header-right">
            <span class="difficulty-badge" id="challenge-difficulty">Medium</span>
          </div>
        </div>
        
        <!-- Challenge Objective -->
        <div class="challenge-objective-card">
          <p id="challenge-description">Objective text goes here...</p>
        </div>
        
        <!-- Staff & Music Area -->
        <div class="staff-section">
          <div class="staff-controls">
            <button class="btn btn-secondary btn-sm" id="btn-play-analysis">
              <span class="icon">▶</span> {% if locale == 'es' %}Escuchar Obra{% else %}Play Piece{% endif %}
            </button>
            <button class="btn btn-stop btn-sm hidden" id="btn-stop-analysis">
              <span class="icon">■</span> {% if locale == 'es' %}Detener{% else %}Stop{% endif %}
            </button>
            <button class="btn btn-secondary btn-sm" id="btn-theory-analysis">
              <span class="icon">💡</span> {% if locale == 'es' %}Teoría{% else %}Theory{% endif %}
            </button>
            <button class="btn btn-secondary btn-sm" id="btn-aids-analysis">
              <span class="icon">🔍</span> {% if locale == 'es' %}Ayudas{% else %}Aids{% endif %}
            </button>
            <span class="control-tip">
              {% if locale == 'es' %}💡 Selecciona una nota o silencio en la partitura y luego elige una nota de la paleta para cambiar su altura.{% else %}💡 Select a note or rest on the staff, then choose a note from the palette to change its pitch.{% endif %}
            </span>
          </div>
          
          <!-- Interactive Staff Canvas -->
          <div class="staff-wrapper">
            <div id="analysis-staff-area"></div>
          </div>
          
          <!-- Reconstruction Palette -->
          <div class="palette-section" id="reconstruction-palette">
            <h4>{% if locale == 'es' %}Paleta de Notas{% else %}Note Palette{% endif %}</h4>
            <div class="note-badges-group" id="available-note-badges">
              <!-- Dynamically populated available note buttons (like badges) -->
            </div>
          </div>
        </div>
        
        <!-- Question Section -->
        <div class="analysis-question-card">
          <h3>{% if locale == 'es' %}Pregunta de Análisis{% else %}Analysis Question{% endif %}</h3>
          <p class="question-text" id="question-text">Question text...</p>
          
          <form class="options-group" id="question-form">
            <!-- Dynamically populated multiple-choice radio options -->
          </form>
        </div>
        
        <!-- Feedback Messages -->
        <div class="feedback-area" id="analysis-feedback-container" style="display: none; margin-bottom: 1.5rem;"></div>
        
        <!-- Action Buttons -->
        <div class="analysis-actions">
          <button class="btn btn-secondary" id="btn-reset-analysis">
            {% if locale == 'es' %}Reiniciar{% else %}Reset{% endif %}
          </button>
          <button class="btn btn-success btn-large" id="btn-submit-analysis">
            {% if locale == 'es' %}Validar Respuesta{% else %}Validate Answer{% endif %} <span class="icon">➔</span>
          </button>
        </div>
      </div>
    </main>
    
  </div>
</div>

<!-- Custom Results Modal -->
<div class="modal-overlay hidden" id="analysis-result-modal">
  <div class="result-modal glass-panel">
    <div class="result-icon" id="result-icon">🎉</div>
    <h2 id="result-title">{% if locale == 'es' %}¡Desafío Completado!{% else %}Challenge Completed!{% endif %}</h2>
    
    <div class="stars-container" id="result-stars">
      <span class="modal-star active">★</span>
      <span class="modal-star active">★</span>
      <span class="modal-star">★</span>
    </div>
    
    <p id="result-feedback">Feedback message...</p>
    
    <div class="result-stats">
      <div class="stat-box">
        <span class="stat-label">XP</span>
        <span class="stat-value" id="result-xp">+75</span>
      </div>
    </div>
    
    <!-- Score Penalty Breakdown -->
    <div class="score-breakdown-container" id="analysis-score-breakdown-area" style="display:none; margin: 0.5rem 0 1rem; font-size: 0.95rem; color: #a0a0b8; justify-content: center; gap: 0.5rem;">
      <span id="analysis-breakdown-base-score">Base: 100%</span> | 
      <span id="analysis-breakdown-penalty" style="color: #ff5252;">{% if locale == 'es' %}Ayudas: -20%{% else %}Aids: -20%{% endif %}</span>
    </div>
    
    <button class="btn btn-success btn-large" id="result-btn-close">
      {% if locale == 'es' %}Entendido{% else %}Got it{% endif %}
    </button>
  </div>
</div>

<!-- Theory Modal -->
<div class="modal-overlay hidden" id="analysis-theory-modal">
  <div class="result-modal glass-panel" style="max-width: 600px; width: 95%;">
    <h2>💡 {% if locale == 'es' %}Concepto Teórico{% else %}Theoretical Concept{% endif %}</h2>
    <div id="analysis-theory-modal-content" class="theory-tips-body" style="text-align: left; margin: 1.5rem 0; color: #d0d0e0; font-size: 1.05rem; line-height: 1.5;">
      <!-- Populated dynamically -->
    </div>
    <div class="result-actions" style="margin-top: 0; justify-content: center;">
      <button class="btn btn-success" id="analysis-theory-modal-close">{% if locale == 'es' %}Entendido{% else %}Got it{% endif %}</button>
    </div>
  </div>
</div>

<!-- Visual Aids Modal -->
<div class="modal-overlay hidden" id="analysis-aids-modal">
  <div class="result-modal glass-panel" style="max-width: 600px; width: 95%;">
    <h2>🔍 {% if locale == 'es' %}Panel de Ayudas Visuales{% else %}Visual Aids Panel{% endif %}</h2>
    <p style="color: #a0a0b8; font-size: 0.9rem; margin-bottom: 1.5rem; text-align: center;">
      {% if locale == 'es' %}Si te trabas, activa estas pistas. Cada ayuda activada aplicará un descuento a tu calificación final.{% else %}If you get stuck, activate these aids. Each active aid will apply a deduction to your final score.{% endif %}
    </p>
    <div class="visual-aids-list" style="display: flex; flex-direction: column; gap: 1rem; text-align: left; margin-bottom: 1.5rem;">
      
      <!-- Theory Clue (5% penalty) -->
      <div class="aid-item" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); padding: 1rem; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; gap: 1rem;">
        <div style="flex: 1;">
          <h4 style="margin: 0 0 0.25rem 0; color: #e8e8f0; font-size: 1rem;">📖 {% if locale == 'es' %}Pista 1: Explicación Armónica Detallada{% else %}Aid 1: Detailed Harmonic Hint{% endif %}</h4>
          <p style="margin: 0; color: #a0a0b8; font-size: 0.85rem;">{% if locale == 'es' %}Revela una pista sobre la estructura o notas que componen el acorde final.{% else %}Reveals a hint about the structure or notes forming the final chord.{% endif %}</p>
          <p class="aid-text-reveal hidden" id="aid-theory-text" style="color: #f0c040; font-size: 0.9rem; margin-top: 0.5rem; font-style: italic;"></p>
        </div>
        <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; min-width: 90px;">
          <span style="color: #f0c040; font-weight: bold; font-size: 0.9rem;">-5%</span>
          <button class="btn btn-warn btn-sm" id="btn-toggle-analysis-aid-theory" style="width: 100%; justify-content: center; padding: 4px 8px; font-size: 0.8rem;">{% if locale == 'es' %}Activar{% else %}Activate{% endif %}</button>
        </div>
      </div>

      <!-- Highlight target staff notes/rests (10% penalty) -->
      <div class="aid-item" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); padding: 1rem; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; gap: 1rem;">
        <div style="flex: 1;">
          <h4 style="margin: 0 0 0.25rem 0; color: #e8e8f0; font-size: 1rem;">🎯 {% if locale == 'es' %}Pista 2: Resaltar Silencio/Nota Objetivo{% else %}Aid 2: Highlight Target Stave Note/Rest{% endif %}</h4>
          <p style="margin: 0; color: #a0a0b8; font-size: 0.85rem;">{% if locale == 'es' %}Resalta con un color brillante en el pentagrama la nota o silencio exacto que debes cambiar.{% else %}Highlight in a bright color on the staff the exact note or rest you need to edit.{% endif %}</p>
        </div>
        <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; min-width: 90px;">
          <span style="color: #f0c040; font-weight: bold; font-size: 0.9rem;">-10%</span>
          <button class="btn btn-warn btn-sm" id="btn-toggle-analysis-aid-staff" style="width: 100%; justify-content: center; padding: 4px 8px; font-size: 0.8rem;">{% if locale == 'es' %}Activar{% else %}Activate{% endif %}</button>
        </div>
      </div>

      <!-- Highlight correct note in available badges palette (15% penalty) -->
      <div class="aid-item" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); padding: 1rem; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; gap: 1rem;">
        <div style="flex: 1;">
          <h4 style="margin: 0 0 0.25rem 0; color: #e8e8f0; font-size: 1rem;">🟢 {% if locale == 'es' %}Pista 3: Revelar Nota Correcta en Paleta{% else %}Aid 3: Reveal Correct Note in Palette{% endif %}</h4>
          <p style="margin: 0; color: #a0a0b8; font-size: 0.85rem;">{% if locale == 'es' %}Ilumina en color verde en la paleta inferior la nota que debes asignar.{% else %}Highlight in green color in the bottom palette the correct note you need to place.{% endif %}</p>
        </div>
        <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; min-width: 90px;">
          <span style="color: #f0c040; font-weight: bold; font-size: 0.9rem;">-15%</span>
          <button class="btn btn-warn btn-sm" id="btn-toggle-analysis-aid-palette" style="width: 100%; justify-content: center; padding: 4px 8px; font-size: 0.8rem;">{% if locale == 'es' %}Activar{% else %}Activate{% endif %}</button>
        </div>
      </div>

    </div>
    <div class="result-actions" style="margin-top: 0; justify-content: center;">
      <button class="btn btn-success" id="analysis-aids-modal-close">{% if locale == 'es' %}Entendido{% else %}Got it{% endif %}</button>
    </div>
  </div>
</div>

<script>
  window.__OPUS_LUDUS__ = {
    locale: "{{ locale }}",
    baseUrl: "{{ pathPrefix }}/{{ locale }}/",
    pathPrefix: "{{ pathPrefix }}",
    page: "analysis"
  };
</script>
{% gameBundle %}
