---
layout: layouts/base.njk
---

<div class="progress-dashboard">
  <!-- Progress Header -->
  <div class="dashboard-header">
    <div class="rank-badge-large">🎼</div>
    <div class="progress-info">
      <div class="rank-title">Rango: <span id="rank-display-name">Cargando...</span></div>
      <h2 class="progress-bar-label">
        <span id="completed-count-text">0 / {{ curriculum.totalModules }} Módulos</span>
        <span id="progress-percentage-text" class="progress-pct">0%</span>
      </h2>
      <div class="progress-bar-new">
        <div class="progress-bar-fill-new" id="global-progress"></div>
      </div>
    </div>
    
    <!-- Stats widgets -->
    <div class="dashboard-stats-grid">
      <div class="stat-widget">
        <span class="widget-icon">⚡</span>
        <div class="widget-data">
          <span class="widget-val" id="xp-display">0</span>
          <span class="widget-lbl">Puntos XP</span>
        </div>
      </div>
      <div class="stat-widget">
        <span class="widget-icon">⭐</span>
        <div class="widget-data">
          <span class="widget-val" id="stars-display">0</span>
          <span class="widget-lbl">Estrellas</span>
        </div>
      </div>
      <button class="btn btn-secondary" id="btn-reset-progress" style="margin-left: auto; align-self: center; gap: 0.35rem; font-size: 0.85rem; padding: 0.4rem 0.85rem;" title="{% if locale == 'es' %}Reiniciar Progreso{% else %}Reset Progress{% endif %}">
        🗑️ {% if locale == 'es' %}Reiniciar{% else %}Reset{% endif %}
      </button>
    </div>
  </div>

  <!-- Next challenge CTA widget -->
  <div class="next-challenge-banner" id="next-challenge-banner-container" style="display: none;">
    <div class="banner-text">
      <span class="banner-badge">SIGUIENTE PASO</span>
      <span class="banner-title">Continuar con: <strong class="next-name-text">Cargando...</strong></span>
    </div>
    <a id="next-challenge-btn" href="#" class="btn btn-success banner-btn">
      Jugar Desafío <span class="icon">➔</span>
    </a>
  </div>
</div>

<!-- Search Bar -->
<div class="search-bar-wrapper">
  <span class="search-icon">🔍</span>
  <input type="text" id="modules-search-input" placeholder="Buscar módulos por concepto (ej: clave, escala, ritmo, vals)..." class="search-input">
</div>

{% for level in [1,2,3,4,5,6,7] %}
{% set levelModules = curriculum.byLevel[level] %}
<section class="level-section">
  <div class="level-header">
    <div class="level-number">{{ level }}</div>
    <h2 class="level-title">{{ modules.levels[level] }}</h2>
  </div>
  <div class="module-grid">
    {% for mod in levelModules %}
    <div class="module-card" data-module-id="{{ mod.id }}" data-module-order="{{ mod.order }}" style="--level-bg-url: url('/assets/images/level{{ level }}_bg.png');">
      <span class="module-order">#{{ mod.order }}</span>
      <h3 class="module-name">{{ mod.name[locale] | default(mod.name.en) }}</h3>
      <p class="module-desc">{{ mod.description[locale] | default(mod.description.en) }}</p>
      <div class="module-footer">
        <span class="module-xp">🎵 {{ mod.xpBase }} XP</span>
        <span class="module-stars" id="stars-{{ mod.id }}"></span>
        <a href="/{{ locale }}/play/?module={{ mod.id }}" class="module-action">
          ▶ {{ modules.play }}
        </a>
      </div>
    </div>
    {% endfor %}
  </div>
</section>
{% endfor %}

<script>
(function() {
  var progress = JSON.parse(localStorage.getItem('opus-ludus-progress') || '{}');
  var progressModules = progress.modules || {};
  var totalModules = {{ curriculum.totalModules }};
  
  var mods = document.querySelectorAll('[data-module-id]');
  var totalStars = 0;
  var completedCount = 0;
  
  // Sort modules by order to verify unlock chain
  var sortedMods = Array.from(mods).sort(function(a, b) {
    return parseInt(a.dataset.moduleOrder) - parseInt(b.dataset.moduleOrder);
  });
  
  var nextActiveFound = null;

  sortedMods.forEach(function(el, index) {
    var id = el.dataset.moduleId;
    var order = parseInt(el.dataset.moduleOrder);
    var p = progressModules[id];
    var isCompleted = p && p.completed;
    
    // Check if unlocked
    var isUnlocked = false;
    if (order === 1) {
      isUnlocked = true;
    } else {
      var prevModEl = sortedMods[index - 1];
      if (prevModEl) {
        var prevId = prevModEl.dataset.moduleId;
        var prevProgress = progressModules[prevId];
        if (prevProgress && prevProgress.completed) {
          isUnlocked = true;
        }
      }
    }

    var starsEl = document.getElementById('stars-' + id);
    var actionBtn = el.querySelector('.module-action');
    
    // Add status label badge
    var statusBadge = document.createElement('span');
    statusBadge.className = 'module-status-badge';
    el.insertBefore(statusBadge, el.firstChild);

    if (isCompleted) {
      completedCount++;
      var stars = p.stars || 0;
      starsEl.textContent = '⭐'.repeat(stars) + '☆'.repeat(Math.max(0, 3 - stars));
      el.classList.add('status-completed');
      statusBadge.innerHTML = '✅ Completado';
      statusBadge.classList.add('badge-completed');
      
      // Calculate total stars
      totalStars += stars;
    } else if (isUnlocked) {
      el.classList.add('status-unlocked');
      if (!nextActiveFound) {
        el.classList.add('status-active');
        statusBadge.innerHTML = '🎯 Activo';
        statusBadge.classList.add('badge-active');
        nextActiveFound = el; // Store first unlocked element
      } else {
        statusBadge.innerHTML = '🔓 Disponible';
        statusBadge.classList.add('badge-unlocked');
      }
      starsEl.textContent = '☆☆☆';
    } else {
      el.classList.add('status-locked');
      statusBadge.innerHTML = '🔒 Bloqueado';
      statusBadge.classList.add('badge-locked');
      actionBtn.classList.add('disabled-action');
      actionBtn.removeAttribute('href');
      actionBtn.textContent = '🔒 Bloqueado';
      starsEl.textContent = '';
    }
  });

  // Update header progress overview
  document.getElementById('xp-display').textContent = progress.totalXp || 0;
  document.getElementById('stars-display').textContent = totalStars;

  // Rank Display
  var rankName = progress.rank || 'novice';
  var rankMap = {
    'novice': { es: 'Novicio', en: 'Novice' },
    'apprentice': { es: 'Aprendiz', en: 'Apprentice' },
    'composer': { es: 'Compositor', en: 'Composer' },
    'maestro': { es: 'Maestro', en: 'Maestro' },
    'virtuoso': { es: 'Virtuoso', en: 'Virtuoso' }
  };
  var currentRankText = (rankMap[rankName] && rankMap[rankName]['{{ locale }}']) || rankName;
  document.getElementById('rank-display-name').textContent = currentRankText;

  // Global Progress text
  var modulesWord = '{{ locale }}' === 'es' ? 'Módulos' : 'Modules';
  document.getElementById('completed-count-text').textContent = completedCount + ' / ' + totalModules + ' ' + modulesWord;
  var percent = Math.min(100, (completedCount / totalModules) * 100);
  document.getElementById('global-progress').style.width = percent + '%';
  document.getElementById('progress-percentage-text').textContent = Math.round(percent) + '%';

  // Setup Next Challenge banner
  var bannerContainer = document.getElementById('next-challenge-banner-container');
  var nextChallengeBtn = document.getElementById('next-challenge-btn');
  if (bannerContainer && nextChallengeBtn) {
    if (nextActiveFound) {
      var nextId = nextActiveFound.dataset.moduleId;
      var nextName = nextActiveFound.querySelector('.module-name').textContent;
      nextChallengeBtn.href = '/' + '{{ locale }}' + '/play/?module=' + nextId;
      bannerContainer.querySelector('.next-name-text').textContent = nextName;
      bannerContainer.style.display = 'flex';
    } else if (completedCount === totalModules) {
      bannerContainer.style.display = 'none'; // All completed!
    } else {
      bannerContainer.style.display = 'none';
    }
  }

  // SEARCH AND FILTER MODULES
  var searchInput = document.getElementById('modules-search-input');
  if (searchInput) {
    searchInput.addEventListener('input', function(e) {
      var query = e.target.value.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
      var sections = document.querySelectorAll('.level-section');
      
      sections.forEach(function(sec) {
        var visibleCount = 0;
        var cards = sec.querySelectorAll('.module-card');
        
        cards.forEach(function(card) {
          var name = card.querySelector('.module-name').textContent.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
          var desc = card.querySelector('.module-desc').textContent.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
          var match = name.indexOf(query) !== -1 || desc.indexOf(query) !== -1;
          
          if (match || query === "") {
            card.style.display = 'flex';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });
        
        if (visibleCount > 0 || query === "") {
          sec.style.display = 'block';
        } else {
          sec.style.display = 'none';
        }
      });
    });
  }

  // Reset Progress Event Handler
  var resetBtn = document.getElementById('btn-reset-progress');
  if (resetBtn) {
    resetBtn.addEventListener('click', function() {
      var confirmMsg = '{{ locale }}' === 'es' 
        ? '¿Estás seguro de que deseas reiniciar todo tu progreso? Esta acción no se puede deshacer y borrará todos tus módulos completados.' 
        : 'Are you sure you want to reset all your progress? This action cannot be undone and will delete all your completed modules.';
      if (confirm(confirmMsg)) {
        localStorage.removeItem('opus-ludus-progress');
        localStorage.removeItem('opus-ludus-streak');
        window.location.reload();
      }
    });
  }
})();
</script>
